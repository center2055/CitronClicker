<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>..\assets\branding\citron-icon.ico</ApplicationIcon>
    <AssemblyName>Citron Clicker</AssemblyName>
    <RootNamespace>CitronClicker</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\assets\branding\citron-icon.png" Link="citron_icon.png" />
  </ItemGroup>

</Project>
