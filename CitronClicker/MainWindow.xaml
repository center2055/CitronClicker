<Window x:Class="CitronClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CitronClicker" Height="680" Width="576"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Inter, Segoe UI, sans-serif">
    
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgColor" Color="#0e0e0e"/>
        <SolidColorBrush x:Key="CardBgColor" Color="#66262626"/> <!-- rgba(38, 38, 38, 0.4) -->
        <SolidColorBrush x:Key="AccentColor" Color="#e4f265"/>
        <SolidColorBrush x:Key="AccentDarkColor" Color="#9ca821"/>
        <SolidColorBrush x:Key="TextColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="SubTextColor" Color="#adaaaa"/>
        <SolidColorBrush x:Key="TrackColor" Color="#484847"/>
        <SolidColorBrush x:Key="ItemBgColor" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="ItemHoverBgColor" Color="#20201f"/>
        
        <!-- Custom Slider Style -->
        <Style x:Key="CustomSlider" TargetType="Slider">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="4" Background="#333333" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="{StaticResource AccentColor}" Style="{DynamicResource SliderRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Background="Transparent" Style="{DynamicResource SliderRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="16" Height="16" Background="{StaticResource AccentColor}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}" Stroke="#0e0e0e" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" Height="4" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Border" CornerRadius="12" Background="#484847"/>
                            <Ellipse x:Name="Knob" Width="16" Height="16" Fill="#adaaaa" HorizontalAlignment="Left" Margin="4"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentDarkColor}"/>
                                <Setter TargetName="Knob" Property="Fill" Value="#212500"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Button Style -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#212500"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#e4f265" Offset="0.0"/>
                                    <GradientStop Color="#9ca821" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HotkeyButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="BorderBrush" Value="#484847"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2c2c2c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2c2c2c"/>
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextColor}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgColor}" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <!-- Blurred Background Ellipses -->
        <Ellipse Width="500" Height="500" Fill="#e4f265" Opacity="0.03" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-50,-50,0" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="120"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="300" Height="300" Fill="#fae44c" Opacity="0.02" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-15,0,0,-15" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="100"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="24,16,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Citron Clicker" FontSize="24" FontWeight="Black" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Active Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource SubTextColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="INACTIVE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SubTextColor}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <Button Content="—" Style="{StaticResource WindowButtonStyle}" Margin="0,0,4,0" Click="MinimizeBtn_Click"/>
                    <Button Content="✕" Style="{StaticResource WindowButtonStyle}" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Card -->
            <Border Grid.Row="1" Background="{StaticResource CardBgColor}" CornerRadius="12">
                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tabs -->
                    <Grid Grid.Row="0" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="LeftTabBtn" Content="LEFT CLICKER" IsChecked="True" Style="{StaticResource TabButtonStyle}" Click="LeftTab_Click"/>
                        <RadioButton x:Name="RightTabBtn" Grid.Column="1" Content="RIGHT CLICKER" Style="{StaticResource TabButtonStyle}" Click="RightTab_Click"/>
                    </Grid>

                    <!-- Sliders -->
                    <Grid Grid.Row="1" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Min CPS -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="MIN CPS" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SubTextColor}" VerticalAlignment="Bottom"/>
                                <TextBlock x:Name="MinCpsText" Text="12" FontSize="24" FontWeight="Black" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider x:Name="MinCpsSlider" Minimum="1" Maximum="20" Value="12" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged" Style="{StaticResource CustomSlider}"/>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#767575" HorizontalAlignment="Left"/>
                                <TextBlock Text="20" FontSize="10" FontWeight="Bold" Foreground="#767575" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- Max CPS -->
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="MAX CPS" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SubTextColor}" VerticalAlignment="Bottom"/>
                                <TextBlock x:Name="MaxCpsText" Text="18" FontSize="24" FontWeight="Black" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider x:Name="MaxCpsSlider" Minimum="1" Maximum="20" Value="18" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged" Style="{StaticResource CustomSlider}"/>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#767575" HorizontalAlignment="Left"/>
                                <TextBlock Text="20" FontSize="10" FontWeight="Bold" Foreground="#767575" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Options Cards -->
                    <Grid Grid.Row="2" Margin="0,16,0,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Block Breaking -->
                        <Border x:Name="BlockBreakingCard" Grid.Row="0" Grid.Column="0" Background="{StaticResource ItemBgColor}" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="BLOCK BREAKING" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Hold mouse still to break" FontSize="10" Foreground="{StaticResource SubTextColor}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <CheckBox x:Name="BlockBreakingCheck" Grid.Column="1" IsChecked="True" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Click="BlockBreakingCheck_Click"/>
                            </Grid>
                        </Border>

                        <!-- Module Hotkey -->
                        <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource ItemBgColor}" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="MODULE HOTKEY" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Click to rebind" FontSize="10" Foreground="{StaticResource SubTextColor}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Button x:Name="HotkeyBtn" Grid.Column="1" Content="V" Click="HotkeyBtn_Click" Style="{StaticResource HotkeyButtonStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Avoid GUI -->
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="{StaticResource ItemBgColor}" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="AVOID GUI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Pause in menus" FontSize="10" Foreground="{StaticResource SubTextColor}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <CheckBox x:Name="AvoidGuiCheck" Grid.Column="1" IsChecked="True" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Click="AvoidGuiCheck_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Master Toggle -->
                    <Border Grid.Row="3" Background="{StaticResource ItemBgColor}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="AUTOCLICKER" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                                <TextBlock Text="Enable or disable the module" FontSize="10" Foreground="{StaticResource SubTextColor}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="MasterToggleCheck" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Click="MasterToggleCheck_Click"/>
                        </Grid>
                    </Border>

                    <!-- Bottom Button -->
                    <Border Grid.Row="4" BorderBrush="#484847" BorderThickness="0,1,0,0" Padding="0,24,0,0">
                        <Button Content="SAVE CONFIGURATION" Style="{StaticResource SaveButtonStyle}" Click="SaveBtn_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <TextBlock Text="made by center2055" Foreground="{StaticResource SubTextColor}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Style="{StaticResource WindowButtonStyle}" Click="GithubBtn_Click" ToolTip="https://github.com/center2055">
                    <Path Data="M12,2C6.477,2 2,6.477 2,12C2,16.418 4.865,20.166 8.839,21.49C9.339,21.582 9.521,21.274 9.521,21.007C9.521,20.767 9.512,19.988 9.508,18.824C6.728,19.428 6.141,17.67 6.141,17.67C5.686,16.515 5.03,16.207 5.03,16.207C4.122,15.586 5.101,15.598 5.101,15.598C6.105,15.668 6.633,16.629 6.633,16.629C7.525,18.158 8.97,17.717 9.54,17.46C9.63,16.814 9.889,16.374 10.176,16.121C7.957,15.869 5.626,15.011 5.626,11.476C5.626,10.468 5.986,9.643 6.58,8.997C6.484,8.744 6.166,7.806 6.671,6.516C6.671,6.516 7.448,6.268 9.498,7.653C10.235,7.448 11.026,7.346 11.813,7.342C12.599,7.346 13.39,7.448 14.128,7.653C16.177,6.268 16.953,6.516 16.953,6.516C17.459,7.806 17.141,8.744 17.046,8.997C17.641,9.643 18,10.468 18,11.476C18,15.022 15.665,15.865 13.438,16.112C13.798,16.422 14.119,17.034 14.119,17.986C14.119,19.351 14.11,20.453 14.11,20.767C14.11,21.036 14.291,21.344 14.791,21.248C18.765,19.914 21.631,16.166 21.631,12C21.631,6.477 17.154,2 11.631,2H12Z" 
                          Fill="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Border>
</Window>
